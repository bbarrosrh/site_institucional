---
import Root from "@/components/Layout/Root.astro";
import Banner from "@/components/Layout/Banner.astro";
import Introduction from "@/components/Sections/About/Introduction.astro";
import Mission from "@/components/Sections/Shared/Mission.astro";
import atenas from "@/assets/images/About/atenas.png";
import Programs from "@/components/Sections/About/Programs/index.astro";
import Recognitions from "@/components/Sections/About/Recognitions/index.astro";
import People from "@/components/Sections/Shared/People/index.astro";
import Team from "@/components/Sections/About/Team.astro";
import CallToAction from "@/components/Sections/Shared/CallToAction.astro";

export const prerender = true;
---

<Root
  title="Sobre Nós"
  description="Há 18 anos unindo Psicologia e Recursos Humanos: conheça a história da B.Barros e sua atuação em Desenvolvimento Humano, Mentoria para Líderes e Posicionamento Profissional."
>
  <Banner eyebrow="Sobre Nós" title="Conheça a nossa história" />
  <Introduction />
  <Mission
    mission="Revelar a essência dos profissionais e transformá-los em líderes preparados para o futuro do trabalho."
    image={atenas}
  />
  <Programs />
  <People title="Conheça nossa rede de mentores" />
  <Recognitions />
  <Team />
  <CallToAction
    title="Pronto para dar o próximo passo?"
    subtitle="Vamos conversar sobre qual caminho faz mais sentido para o seu momento."
  />
</Root>
