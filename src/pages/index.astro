---
import Root from "@/components/Layout/Root.astro";
import HeroBanner from "@/components/Sections/Home/HeroBanner/index.astro";
import Stats from "@/components/Sections/Home/Stats.astro";
import About from "@/components/Sections/Home/About.astro";
import ForWhom from "@/components/Sections/Home/ForWhom/index.astro";
import Ecosystem from "@/components/Sections/Home/Ecosystem/index.astro";
import Differentials from "@/components/Sections/Home/Differentials/index.astro";
import Testimonials from "@/components/Sections/Home/Testimonials/index.astro";
import Faq from "@/components/Sections/Home/Faq/index.astro";
import BlogSection from "@/components/Sections/Home/Blog/index.astro";
import Contact from "@/components/Sections/Shared/Contact.astro";
import adao from "@/assets/images/Home/adao.png";

export const prerender = true;
---

<Root title="Home">
  <HeroBanner />
  <Stats />
  <About />
  <ForWhom />
  <Ecosystem />
  <Differentials />
  <Testimonials />
  <Faq />
  <BlogSection />
  <Contact image={adao} />
</Root>
