---
import Root from "@/components/Layout/Root.astro";
import PortableText from "@/components/PortableText.astro";
import SharePost from "@/components/Sections/BlogIntern/SharePost.astro";
import { sanityFetch } from "@/sanity/client";
import { BLOG_SLUGS_QUERY, BLOG_POST_QUERY, type BlogPostFull } from "@/sanity/schemas/Blog/data";
import { EXAMPLE_POST_SLUG, exampleBlogPostFull } from "@/sanity/schemas/Blog/exampleData";
import placeholder from "@/assets/images/placeholder.png";
import { Route } from "@/data/routes";

export const prerender = true;

export async function getStaticPaths() {
  const slugs =
    (await sanityFetch<{ slug: string }[]>(BLOG_SLUGS_QUERY, {}, { perspective: "published" })) ??
    [];
  if (slugs.length === 0) {
    slugs.push({ slug: EXAMPLE_POST_SLUG });
  }
  return slugs.map(({ slug }) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const fetchedPost = await sanityFetch<BlogPostFull>(
  BLOG_POST_QUERY,
  { slug },
  { perspective: "published" }
);
const post = fetchedPost ?? (slug === EXAMPLE_POST_SLUG ? exampleBlogPostFull : null);

if (!post) return Astro.redirect(Route.NOT_FOUND);

const formattedDate = new Date(post.publishedAt).toLocaleDateString("pt-BR", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

const pageUrl = Astro.url.href;
const heroImageSrc = post.image ? `${post.image}?w=1400&auto=format` : placeholder.src;

const firstParagraph = post.body?.find(
  (block): block is Extract<typeof block, { _type: "block" }> =>
    block._type === "block" && block.style === "normal"
);
const excerptText = firstParagraph?.children.map((child) => child.text).join("") ?? "";
const description =
  excerptText.length > 155 ? `${excerptText.slice(0, 155).trim()}…` : excerptText || undefined;
---

<Root title={post.title} description={description} image={post.image ?? undefined}>
  <div class="relative h-auto lg:h-96 w-full overflow-hidden bg-slate-900">
    <img
      src={heroImageSrc}
      alt={post.title}
      class="absolute inset-0 h-full w-full object-cover opacity-70"
    />
    <div class="absolute inset-0 bg-linear-to-t from-black/60 to-black/30"></div>
    <div class="relative lg:absolute lg:inset-x-0 lg:bottom-0 section-container pb-8 sm:pb-10">
      <p class="text-sm sm:text-lg font-medium text-white/70 mb-2 pt-32 lg:pt-0 max-w-5xl mx-auto">
        {formattedDate}
      </p>
      <h1
        class="text-2xl sm:text-3xl lg:text-4xl font-semibold text-white leading-snug max-w-5xl mx-auto"
      >
        {post.title}
      </h1>
    </div>
  </div>

  <div class="section-container py-10 lg:py-16">
    <div class="max-w-5xl mx-auto">
      {post.author && <p class="text-lg font-medium text-white mb-10">Autor: {post.author}</p>}
      {post.body && <PortableText blocks={post.body} />}
      <SharePost url={pageUrl} title={post.title} />
    </div>
  </div>
</Root>
