---
import Root from "@/components/Layout/Root.astro";
import MiniHeroBanner from "@/components/Sections/Shared/MiniHeroBanner/index.astro";
import CardCarousel from "@/components/Sections/Shared/CardCarousel/index.astro";
import { helpSlides } from "@/data/Mentoring/help";
---

<Root title="Mentoria">
  <MiniHeroBanner
    icon="bussola"
    title="Mentorias que transformam decisões em conquistas"
    subtitle="Usando metodologias exclusivas, construídas ao longo de 18 anos de Recursos Humanos e Psicologia, com atendimento direto e foco em resultado."
  />
  <CardCarousel title="Como podemos te ajudar" slides={helpSlides} />
</Root>
