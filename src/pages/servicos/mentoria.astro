---
import Root from "@/components/Layout/Root.astro";
import MiniHeroBanner from "@/components/Sections/Shared/MiniHeroBanner/index.astro";
import CardCarousel from "@/components/Sections/Shared/CardCarousel/index.astro";
import Methodologies from "@/components/Sections/Mentoria/Methodologies.astro";
import DevelopedSkills from "@/components/Sections/Mentoria/DevelopedSkills/index.astro";
import CoveredTopics from "@/components/Sections/Shared/CoveredTopics/index.astro";
import Mentors from "@/components/Sections/Shared/Mentors/index.astro";
import CallToAction from "@/components/Sections/Shared/CallToAction.astro";

import { helpSlides } from "@/data/Mentoring/help";
import { coveredTopics } from "@/data/Mentoring/coveredTopics";
import { talentBankSubject } from "@/data/contact";
import homemVitruviano from "@/assets/images/Mentoria/homem_vitruviano.png";

export const prerender = true;
---

<Root title="Mentoria">
  <MiniHeroBanner
    icon="bussola"
    title="Mentorias que transformam decisões em conquistas"
    subtitle="Usando metodologias exclusivas, construídas ao longo de 18 anos de Recursos Humanos e Psicologia, com atendimento direto e foco em resultado."
  />
  <CardCarousel title="Como podemos te ajudar" slides={helpSlides} />
  <Methodologies />
  <CoveredTopics title="Conteúdos abordados na mentoria" topics={coveredTopics} />
  <DevelopedSkills />
  <CallToAction
    title="Entre no nosso banco de talentos"
    subtitle="Envie seu currículo e conecte-se a futuras oportunidades que combinam com o seu talento."
    image={homemVitruviano}
    buttonText="Mande seu currículo"
    contactSubject={talentBankSubject}
    noFade
  />
  <Mentors />
  <CallToAction
    title="Pronto para dar o próximo passo?"
    subtitle="Vamos conversar sobre qual caminho faz mais sentido para o seu momento."
  />
</Root>
