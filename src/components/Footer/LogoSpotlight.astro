---
interface Props {
  raw: string;
  id: string;
  ariaLabel?: string;
  class?: string;
}

const { raw, id, ariaLabel, class: className } = Astro.props;
---

<div id={`${id}-container`} class:list={["relative overflow-hidden", className]}>
  <div
    id={`${id}-reveal`}
    class="w-full select-none block lg:opacity-40 [&_svg]:w-full [&_svg]:h-auto [&_svg]:block"
    aria-label={ariaLabel}
    set:html={raw}
  />
</div>

<script define:vars={{ id }} is:inline>
  const container = document.getElementById(`${id}-container`);
  const logo = document.getElementById(`${id}-reveal`);

  if (container && logo) {
    let cx = 0,
      cy = 0;
    let mx = 0,
      my = 0;
    let hasEntered = false;
    let isLg = window.innerWidth >= 1024;

    const render = () => {
      if (isLg) {
        cx += (mx - cx) * 0.08;
        cy += (my - cy) * 0.08;
        const radius = hasEntered ? window.innerWidth * 0.5 : 0;
        const mask = `radial-gradient(circle ${radius}px at ${cx}px ${cy}px, black 10%, transparent 100%)`;
        logo.style.maskImage = mask;
        logo.style.webkitMaskImage = mask;
      } else {
        logo.style.maskImage = "";
        logo.style.webkitMaskImage = "";
      }
      requestAnimationFrame(render);
    };

    requestAnimationFrame(render);

    let lastClientX = 0;
    let lastClientY = 0;

    const updateTarget = () => {
      if (!isLg) return;
      const r = container.getBoundingClientRect();
      mx = lastClientX - r.left;
      my = lastClientY - r.top;
      if (!hasEntered) {
        cx = mx;
        cy = my;
        hasEntered = true;
      }
    };

    window.addEventListener("mousemove", (e) => {
      lastClientX = e.clientX;
      lastClientY = e.clientY;
      updateTarget();
    });

    window.addEventListener("scroll", updateTarget, { passive: true });

    window.addEventListener("resize", () => {
      const wasLg = isLg;
      isLg = window.innerWidth >= 1024;
      if (wasLg && !isLg) hasEntered = false;
    });
  }
</script>
