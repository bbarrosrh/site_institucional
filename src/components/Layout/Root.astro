---
import "@/styles/global.css";
import "@fontsource/lora/400.css";
import "@fontsource/lora/500.css";
import "@fontsource/lora/600.css";
import "@fontsource/lora/700.css";
import "@fontsource/lora/400-italic.css";
import "@fontsource/manrope/200.css";
import "@fontsource/manrope/500.css";
import "@fontsource/manrope/600.css";
import "@fontsource/manrope/700.css";
import "@fontsource/caveat/500.css";
import { Navbar } from "@/components/Navbar";
import SEO from "./SEO.astro";
import Footer from "@/components/Footer/index.astro";
import ContactModal from "@/components/Sections/Shared/ContactModal.astro";
import { cn } from "@/utils/className";

interface Props {
  title: string;
  description?: string;
  image?: ImageMetadata | string;
}

const { title, description, image } = Astro.props;

const hasFancyScrollbar = import.meta.env.PUBLIC_FANCY_SCROLLBAR === "true";
---

<!doctype html>
<html lang="pt-BR" class={cn(hasFancyScrollbar && "fancy-scrollbar")}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <SEO title={title} description={description} image={image} />
  </head>

  <body class="font-sans font-medium antialiased bg-black text-white">
    <Navbar client:load currentPath={Astro.url.pathname} />
    <main>
      <slot />
    </main>
    <Footer />

    <ContactModal />
  </body>
</html>

<script>
  import { isContactModalOpen, presetContactSubject } from "@/stores/contactModal";

  document.addEventListener("click", (event) => {
    const trigger = (event.target as HTMLElement).closest<HTMLElement>("[data-contact-cta]");
    if (!trigger) return;

    event.preventDefault();
    presetContactSubject.set(trigger.dataset.contactSubject ?? null);
    isContactModalOpen.set(true);
  });
</script>

<script>
  import { openProduct, isProductModalOpen } from "@/stores/storeModal";
  import type { Product } from "@/sanity/schemas/Store/data";

  const openProductModal = (trigger: HTMLElement) => {
    if (!trigger.dataset.product) return;

    const product = JSON.parse(trigger.dataset.product) as Product;
    if (product.soldOut) return;

    openProduct.set(product);
    isProductModalOpen.set(true);
  };

  document.addEventListener("click", (event) => {
    const trigger = (event.target as HTMLElement).closest<HTMLElement>(".product-card-trigger");
    if (trigger) openProductModal(trigger);
  });

  document.addEventListener("keydown", (event) => {
    if (event.key !== "Enter" && event.key !== " ") return;
    const trigger = (event.target as HTMLElement).closest<HTMLElement>(".product-card-trigger");
    if (!trigger) return;

    event.preventDefault();
    openProductModal(trigger);
  });
</script>

<script>
  const EASE = 0.05;

  function initFancyScroll() {
    if (!document.documentElement.classList.contains("fancy-scrollbar")) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const maxScroll = () => document.documentElement.scrollHeight - window.innerHeight;

    let current = window.scrollY;
    let target = window.scrollY;
    let rafId: number | null = null;

    const tick = () => {
      current += (target - current) * EASE;

      if (Math.abs(target - current) < 0.5) {
        current = target;
        window.scrollTo(0, current);
        rafId = null;
        return;
      }

      window.scrollTo(0, current);
      rafId = requestAnimationFrame(tick);
    };

    window.addEventListener(
      "wheel",
      (event) => {
        event.preventDefault();

        if (rafId === null) {
          current = window.scrollY;
          target = window.scrollY;
        }

        target = Math.max(0, Math.min(target + event.deltaY, maxScroll()));

        if (rafId === null) rafId = requestAnimationFrame(tick);
      },
      { passive: false }
    );
  }

  initFancyScroll();
</script>