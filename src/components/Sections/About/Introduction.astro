---
import DuoSection from "@/components/Layout/Section/Duo.astro";
import compass from "@/assets/images/About/compass.png";
---

<DuoSection sectionClass="bg-black text-white max-lg:pb-0">
  <div slot="left" class="flex flex-col gap-6 text-center lg:text-left">
    <div class="flex flex-col gap-1 border-secondary lg:border-l-8 lg:pl-5">
      <h2 class="font-heading text-2xl sm:text-4xl font-semibold text-primary">
        Uma trajetória que começou na psicologia
      </h2>
    </div>

    <p class="leading-relaxed text-white sm:text-lg">
      A trajetória da B.Barros começou há 18 anos no universo dos Recursos Humanos, guiada pela
      Psicologia e pela convicção de que desenvolver pessoas transforma organizações e a sociedade.
    </p>

    <p class="leading-relaxed text-white sm:text-lg">
      Há quatro anos, nasceu a B.Barros, uma consultoria especializada em Desenvolvimento Humano,
      Mentoria para Líderes, Recrutamento & Seleção Estratégica e Posicionamento Profissional,
      atuando com pessoas físicas e empresas.
    </p>
  </div>

  <div slot="right" class="max-lg:full-bleed">
    <img
      src={compass.src}
      alt="Bússola, símbolo da mentoria de carreira da B.Barros"
      class="w-full lg:rounded-3xl object-cover lg:h-full lg:aspect-auto"
    />
  </div>
</DuoSection>
