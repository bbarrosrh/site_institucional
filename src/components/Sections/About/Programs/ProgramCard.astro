---
import { Button } from "@/components/Button";
import { Icon } from "@/components/Icon";

interface Props {
  name: string;
  title: string;
  description: string;
  href: string;
}

const { name, title, description, href } = Astro.props;
---

<div class="flex flex-col gap-4">
  <div
    class="relative flex flex-col justify-end gap-3 overflow-hidden rounded-2xl bg-black p-6 pt-20 min-h-72"
  >
    <p
      class="pointer-events-none absolute top-3 left bg-linear-to-b from-primary to-black bg-clip-text font-heading text-7xl font-bold text-transparent select-none sm:text-9xl"
    >
      {name}<sup
        class="-ml-1 font-sans font-extralight! align-super text-2xl text-primary sm:text-4xl"
        >®</sup
      >
    </p>

    <h3 class="relative font-semibold text-white font-sans! lg:text-xl">{title}</h3>
    <p class="relative text-white/85 lg:text-lg leading-relaxed">{description}</p>
  </div>

  <Button href={href} target="_blank" size="lg" className="w-full">
    Saiba Mais
    <Icon name="arrow-right" />
  </Button>
</div>
