const { viewBox, path } = icons[variant];
const gradientId = `gold-icon-${variant}`;
---

<svg
  viewBox={viewBox}
  class={`drop-shadow-[0_4px_0_#FFF5E2] ${className ?? ""}`}
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <defs>
    <linearGradient id={gradientId} x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#A5845A"></stop>
      <stop offset="0.0919" stop-color="#BA9D71"></stop>
      <stop offset="0.239" stop-color="#D8BF91"></stop>
      <stop offset="0.3187" stop-color="#E3CC9D"></stop>
      <stop offset="0.4707" stop-color="#E1CA9B"></stop>
      <stop offset="0.4712" stop-color="#B39864"></stop>
      <stop offset="0.6262" stop-color="#967941"></stop>
      <stop offset="0.6957" stop-color="#8B6D34"></stop>
      <stop offset="0.7947" stop-color="#8E6F38"></stop>
      <stop offset="0.893" stop-color="#967744"></stop>
      <stop offset="0.9907" stop-color="#A38358"></stop>
      <stop offset="1" stop-color="#A5845A"></stop>
    </linearGradient>
  </defs>
  <path d={path} fill={`url(#${gradientId})`}></path>
</svg>

<script define:vars={{ gradientId }} is:inline>
  const gradient = document.getElementById(gradientId);

  if (gradient && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    const MAX_SHIFT = 0.18;
    const DRIFT_TAU = 0.2;

    let target = 0;
    let current = 0;
    let lastTime = null;

    window.addEventListener("mousemove", (event) => {
      const normalizedY = (event.clientY / window.innerHeight) * 2 - 1;
      target = normalizedY * MAX_SHIFT;
    });

    const tick = (time) => {
      if (lastTime === null) lastTime = time;
      const dt = (time - lastTime) / 1000;
      lastTime = time;

      const alpha = 1 - Math.exp(-dt / DRIFT_TAU);
      current += (target - current) * alpha;

      gradient.setAttribute("gradientTransform", `translate(0 ${current})`);
      requestAnimationFrame(tick);
    };

    requestAnimationFrame(tick);
  }
</script>
