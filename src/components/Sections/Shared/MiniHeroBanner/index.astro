---
import { Button } from "@/components/Button";
import { Icon } from "@/components/Icon";
import type { IconName } from "@/components/Icon/IconName";
import GoldIcon, { type MiniHeroIcon } from "./GoldIcon.astro";

interface Props {
  icon: MiniHeroIcon;
  title: string;
  subtitle: string;
}

const { icon, title, subtitle } = Astro.props;

const eyebrows: Record<MiniHeroIcon, string> = {
  bussola: "B.Barros Mentoring",
  livro: "B.Barros Academy",
  maleta: "B.Barros Business",
};

const eyebrowIcons: Record<MiniHeroIcon, IconName> = {
  bussola: "compass",
  livro: "book",
  maleta: "briefcase",
};

const eyebrow = eyebrows[icon];
const eyebrowIcon = eyebrowIcons[icon];
---

<section class="relative flex h-[75dvh] items-center overflow-hidden bg-black py-24 text-white">
  <div class="bg-grid pointer-events-none absolute inset-0"></div>

  <div class="section-container relative grid items-center gap-10 lg:grid-cols-2">
    <div class="flex flex-col items-center gap-8 lg:gap-12 text-center lg:items-start lg:text-left">
      <div class="flex flex-col gap-5 max-lg:items-center">
        <div class="flex max-lg:flex-col items-center gap-4">
          <span
            class="inline-flex size-10 shrink-0 items-center justify-center rounded-lg bg-white text-black"
          >
            <Icon name={eyebrowIcon} className="size-7" />
          </span>
          <p class="font-heading text-lg font-semibold sm:text-2xl">{eyebrow}</p>
        </div>

        <h1
          class="max-w-3xl -mb-2 font-heading text-3xl font-semibold text-primary sm:text-4xl lg:text-5xl"
        >
          {title}
        </h1>
      </div>
      <p class="w-4/5 leading-relaxed text-white sm:text-xl">{subtitle}</p>

      <div>
        <Button variant="secondary" size="lg">
          Agende uma conversa
          <Icon name="arrow-right"/>
        </Button>
      </div>
    </div>

    <div class="hidden justify-center lg:flex lg:justify-end">
      <GoldIcon variant={icon} class="size-72 lg:size-96 xl:size-128" />
    </div>
  </div>
</section>
