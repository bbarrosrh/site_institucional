---
import Modal from "@/components/Modal.astro";
import ContactForm from "@/components/Sections/Shared/ContactForm/index.astro";
import { Route } from "@/data/routes";
import { participateItems } from "@/data/Institute/participate";

const isInstitutePage = Astro.url.pathname === Route.INSTITUTE;
---

<Modal id="contact-modal">
  <ContactForm
    subjectLabel={isInstitutePage ? "Tenho interesse em" : undefined}
    subjectOptions={isInstitutePage ? participateItems.map((item) => item.title) : undefined}
  />
</Modal>

<script>
  import { initModal } from "@/utils/modal";
  import { isContactModalOpen } from "@/stores/contactModal";

  let recaptchaLoaded = !!document.querySelector('script[src*="recaptcha/api.js"]');
  const ensureRecaptcha = () => {
    if (recaptchaLoaded) return;
    recaptchaLoaded = true;

    const script = document.createElement("script");
    script.src = "https://www.google.com/recaptcha/api.js";
    script.async = true;
    script.defer = true;
    document.head.appendChild(script);
  };

  initModal("contact-modal", isContactModalOpen, ensureRecaptcha);
</script>
