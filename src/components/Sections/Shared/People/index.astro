---
import { PeopleList } from "@/components/Sections/Shared/People/PeopleList";
import { sanityFetch } from "@/sanity/client";
import { MENTORS_QUERY, PARTNERS_QUERY, type Person } from "@/sanity/schemas/People/data";

interface Props {
  title: string;
  variant?: "mentor" | "partner";
}

const { title, variant = "mentor" } = Astro.props;

const query = variant === "partner" ? PARTNERS_QUERY : MENTORS_QUERY;
const people = (await sanityFetch<Person[]>(query)) ?? [];
---

{
  people.length > 0 && (
    <section class="section-wrapper bg-black text-white">
      <div class="section-container flex flex-col gap-8 lg:gap-12">
        <h2 class="section-title font-heading">{title}</h2>

        <PeopleList people={people} client:load />
      </div>
    </section>
  )
}
