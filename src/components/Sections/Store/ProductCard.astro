---
import type { Product } from "@/data/Store/products";

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<div class="flex flex-col overflow-hidden rounded-2xl bg-black">
  <div class="h-64 w-full bg-white"></div>

  <div class="flex flex-1 flex-col gap-3 p-6 bg-tertiary">
    <h3 class="font-heading text-xl font-semibold text-white">{product.name}</h3>
    <p class="text-sm leading-relaxed text-white/70">{product.description}</p>

    <div class="mt-auto pt-3">
      <p class="font-heading text-2xl font-bold text-white">R$ {product.price}</p>
    </div>
  </div>
</div>
