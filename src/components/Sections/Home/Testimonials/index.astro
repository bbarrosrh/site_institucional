---
import Section from "@/components/Layout/Section/index.astro";
import { Button } from "@/components/Button";
import { CarouselNavButton } from "@/components/CarouselNavButton";
import TestimonialCard from "./TestimonialCard.astro";
import { sanityFetch } from "@/sanity/client";
import { TESTIMONIALS_QUERY, type Testimonial } from "@/sanity/schemas/Testimonials/data";

const COLUMN_COUNT = 3;
const VISIBLE_ROWS = 2;
const VISIBLE_COUNT = COLUMN_COUNT * VISIBLE_ROWS;

const testimonials = (await sanityFetch<Testimonial[]>(TESTIMONIALS_QUERY)) ?? [];
const hasMore = testimonials.length > VISIBLE_COUNT;
---

<Section>
  <div class="flex flex-col items-center gap-1 text-center">
    <p class="section-eyebrow">Depoimentos de clientes</p>
    <h2 class="section-title">Histórias reais de quem já virou a chave</h2>
  </div>

  {
    testimonials.length > 0 && (
      <>
        <div class="testimonials-block w-full flex flex-col gap-6 lg:hidden">
          <div class="testimonials-track flex gap-4 overflow-x-auto scroll-smooth pb-2 snap-x snap-mandatory scrollbar-none [&::-webkit-scrollbar]:hidden">
            {testimonials.map((testimonial) => (
              <div class="w-full min-w-0 shrink-0 snap-start">
                <TestimonialCard
                  name={testimonial.name}
                  role={testimonial.role}
                  quote={testimonial.quote}
                />
              </div>
            ))}
          </div>

          <div class="flex items-center justify-between gap-6">
            <CarouselNavButton
              client:load
              direction="prev"
              label="Anterior"
              className="testimonials-prev"
            />

            <div class="h-2 w-full overflow-hidden rounded-full bg-white/10">
              <div class="testimonials-progress h-full w-1/2 rounded-full bg-primary transition-[width] duration-300 ease-out" />
            </div>

            <CarouselNavButton
              client:load
              direction="next"
              label="Próximo"
              className="testimonials-next"
            />
          </div>
        </div>

        <div class="testimonials-block hidden w-full lg:flex lg:flex-col lg:gap-8">
          <div class="relative w-full">
            <div class="testimonials-grid grid grid-cols-3 gap-6 transition-[max-height] duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]">
              {testimonials.map((testimonial) => (
                <div class="testimonial-item">
                  <TestimonialCard
                    name={testimonial.name}
                    role={testimonial.role}
                    quote={testimonial.quote}
                  />
                </div>
              ))}
            </div>

            {hasMore && (
              <div class="testimonials-fade pointer-events-none absolute inset-x-0 bottom-0 h-40 bg-linear-to-b from-transparent to-black" />
            )}
          </div>

          {hasMore && (
            <Button
              type="button"
              variant="outline"
              size="lg"
              className="testimonials-more self-center"
              data-visible-count={VISIBLE_COUNT}
              data-column-count={COLUMN_COUNT}
            >
              Ver mais
            </Button>
          )}
        </div>
      </>
    )
  }
</Section>

<script>
  document.querySelectorAll<HTMLElement>(".testimonials-track").forEach((track) => {
    const scope = track.closest(".testimonials-block") ?? document;
    const progressFill = scope.querySelector<HTMLElement>(".testimonials-progress");
    const prevButton = scope.querySelector<HTMLButtonElement>(".testimonials-prev");
    const nextButton = scope.querySelector<HTMLButtonElement>(".testimonials-next");
    const cards = Array.from(track.children) as HTMLElement[];
    if (!prevButton || !nextButton || cards.length === 0) return;

    const gapPx = () => parseFloat(getComputedStyle(track).columnGap) || 0;
    const cardStep = () => cards[0].getBoundingClientRect().width + gapPx();
    const maxScroll = () => Math.max(0, track.scrollWidth - track.clientWidth);

    let stops = [0];

    const computeStops = () => {
      const max = maxScroll();
      const step = cardStep();
      const result = [0];

      if (step > 0) {
        let next = step;
        while (next < max - 1 && result.length < cards.length) {
          result.push(next);
          next += step;
        }
      }

      if (max > result[result.length - 1] + 1) result.push(max);
      return result;
    };

    const syncStops = () => {
      stops = computeStops();
    };

    const activeStopIndex = () => {
      let closest = 0;
      let closestDistance = Infinity;
      stops.forEach((stop, index) => {
        const distance = Math.abs(track.scrollLeft - stop);
        if (distance < closestDistance) {
          closestDistance = distance;
          closest = index;
        }
      });
      return closest;
    };

    const goToStop = (index: number) => {
      const clamped = Math.max(0, Math.min(index, stops.length - 1));
      track.scrollTo({ left: stops[clamped], behavior: "smooth" });
    };

    const update = () => {
      const index = activeStopIndex();

      if (progressFill) {
        const ratio = stops.length > 1 ? index / (stops.length - 1) : 1;
        progressFill.style.width = `${Math.max(4, ratio * 100)}%`;
      }

      prevButton.disabled = index <= 0;
      nextButton.disabled = index >= stops.length - 1;
    };

    prevButton.addEventListener("click", () => goToStop(activeStopIndex() - 1));
    nextButton.addEventListener("click", () => goToStop(activeStopIndex() + 1));

    track.addEventListener("scroll", update, { passive: true });
    window.addEventListener("resize", () => {
      syncStops();
      update();
    });

    syncStops();
    update();
    setTimeout(() => {
      syncStops();
      update();
    }, 50);
  });

  const grid = document.querySelector<HTMLElement>(".testimonials-grid");
  const fade = document.querySelector<HTMLElement>(".testimonials-fade");
  const moreButton = document.querySelector<HTMLButtonElement>(".testimonials-more");

  if (grid && moreButton) {
    const items = Array.from(grid.children) as HTMLElement[];
    const visibleCount = Number(moreButton.dataset.visibleCount) || items.length;
    const columnCount = Number(moreButton.dataset.columnCount) || 1;
    const initialRows = Math.ceil(visibleCount / columnCount);
    const totalRows = Math.ceil(items.length / columnCount);

    const ROWS_PER_CLICK = 1.5;
    let currentRows = initialRows;

    const rowBottom = (rowCount: number) => {
      const gridTop = grid.getBoundingClientRect().top;
      const clampedRowCount = Math.min(Math.max(rowCount, 1), totalRows);
      const itemIndex = Math.min(clampedRowCount * columnCount, items.length) - 1;
      const referenceItem = items[itemIndex] ?? items[items.length - 1];
      if (!referenceItem) return grid.scrollHeight;
      return referenceItem.getBoundingClientRect().bottom - gridTop;
    };

    const heightForRows = (rows: number) => {
      const floorRows = Math.floor(rows);
      const frac = rows - floorRows;
      const lower = rowBottom(floorRows);
      if (frac === 0) return lower;
      const upper = rowBottom(floorRows + 1);
      return lower + frac * (upper - lower);
    };

    const render = () => {
      const isExpanded = currentRows >= totalRows;
      grid.style.overflow = isExpanded ? "" : "hidden";
      grid.style.maxHeight = isExpanded
        ? `${grid.scrollHeight}px`
        : `${heightForRows(currentRows)}px`;
      fade?.classList.toggle("hidden", isExpanded);
      moreButton.textContent = isExpanded ? "Ver menos" : "Ver mais";
    };

    moreButton.addEventListener("click", () => {
      currentRows =
        currentRows >= totalRows ? initialRows : Math.min(currentRows + ROWS_PER_CLICK, totalRows);
      render();
    });

    render();
    window.addEventListener("resize", () => {
      if (currentRows < totalRows) render();
    });
  }
</script>
