---
import DuoSection from "@/components/Layout/Section/Duo.astro";
import { Button } from "@/components/Button";
import { Icon } from "@/components/Icon";
import bruna from "@/assets/images/Home/bruna.png";
import { achievements } from "@/data/Home/achievements";
---

<DuoSection sectionClass="bg-black text-white" leftClass="lg:w-2/3">
  <div
    slot="left"
    class="flex flex-col items-center gap-6 lg:gap-10 text-center lg:items-start lg:text-left"
  >
    <div class="flex flex-col gap-1 lg:border-l-8 lg:border-secondary lg:pl-5">
      <p class="section-eyebrow lg:text-left">Sobre Bruna Barros</p>
      <h2 class="section-title lg:text-left">Propósito com método</h2>
    </div>

    <p class="text-base leading-relaxed text-white lg:text-lg">
      Há 18 anos no universo de Recursos Humanos e há 4 anos à frente da B.Barros RH, uniu
      Psicologia e estratégia para transformar o desenvolvimento humano em resultado real para
      pessoas e empresas.
    </p>

    <div class="flex flex-col gap-5 w-full">
      {
        achievements.map((achievement) => (
          <div class="flex flex-col items-center gap-4 rounded-2xl bg-tertiary/50 p-4 text-center lg:flex-row lg:bg-transparent lg:p-0 lg:text-left">
            <img
              src={achievement.icon.src}
              alt=""
              class="size-12 border border-white shrink-0 rounded-full object-cover"
            />
            <div>
              <p class="font-medium text-white mb-2 lg:mb-1">{achievement.title}</p>
              <p class="text-sm text-white/60">{achievement.description}</p>
            </div>
          </div>
        ))
      }
    </div>

    <div>
      <Button variant="outline">
        Conheça-nos melhor
        <Icon name="arrow-right" />
      </Button>
    </div>
  </div>

  <div slot="right" class="relative ml-auto hidden w-full max-w-md lg:block">
    <div class="relative aspect-square w-full overflow-hidden rounded-3xl bg-tertiary">
      <div class="bg-grid absolute inset-0"></div>
    </div>

    <img
      src={bruna.src}
      alt="Bruna Barros"
      class="absolute right-0 bottom-0 w-4/5 max-w-none object-contain drop-shadow-2xl"
    />
  </div>
</DuoSection>
